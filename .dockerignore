services:

  # ── PostgreSQL ──────────────────────────────────────────
  db:
    image: postgres:16-alpine
    container_name: cpip_db
    restart: unless-stopped
    environment:
      POSTGRES_DB: cpip_db
      POSTGRES_USER: cpip_user
      POSTGRES_PASSWORD: cpip_password
    volumes:
      - postgres_data:/var/lib/postgresql/data
    ports:
      - "5432:5432"
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U cpip_user -d cpip_db"]
      interval: 5s
      timeout: 5s
      retries: 5

  # ── Laravel API ─────────────────────────────────────────
  api:
    build:
      context: ./apps/api
      dockerfile: Dockerfile
    container_name: cpip_api
    restart: unless-stopped
    environment:
      APP_ENV: local
      APP_DEBUG: true
      APP_KEY: ${APP_KEY}
      DB_CONNECTION: pgsql
      DB_HOST: db
      DB_PORT: 5432
      DB_DATABASE: cpip_db
      DB_USERNAME: cpip_user
      DB_PASSWORD: cpip_password
      FRONTEND_URL: http://localhost:3000
    ports:
      - "8000:8080"
    depends_on:
      db:
        condition: service_healthy
    volumes:
      - ./apps/api/storage:/var/www/html/storage

  # ── Next.js Frontend ────────────────────────────────────
  web:
    build:
      context: ./apps/web
      dockerfile: Dockerfile
      args:
        NEXT_PUBLIC_API_BASE_URL: http://localhost:8000
    container_name: cpip_web
    restart: unless-stopped
    environment:
      NEXT_PUBLIC_API_BASE_URL: http://api:8080
    ports:
      - "3000:3000"
    depends_on:
      - api

volumes:
  postgres_data: